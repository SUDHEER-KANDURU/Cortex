# =============================================================================
# Cortex — Environment Variables
# Copy this file to docker/.env and fill in your values.
# Never commit the actual .env file to version control.
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=cortex
POSTGRES_USER=cortex
POSTGRES_PASSWORD=change_me_in_production

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Frontend ───────────────────────────────────────────────────────────────────
# Points to the local FastAPI backend — do not change for local development
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cortex:cortex@postgres:5432/cortex
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexpass

# GitHub API token — generate at github.com/settings/tokens
# Needs: repo, read:user scopes
GITHUB_TOKEN=

# Gemini API key — get at aistudio.google.com
# Leave empty for fully offline mode
GEMINI_API_KEY=

# App config
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
